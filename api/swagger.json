{
    "swagger": "2.0",
    "info": {
        "description": "本地图片上传与管理服务的开发文档。",
        "title": "Go Image Server API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api/v1",
    "paths": {
        "/images": {
            "get": {
                "description": "按日期分组返回图片列表，可通过 date=YYYY-MM-DD 过滤",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "images"
                ],
                "summary": "图片列表",
                "parameters": [
                    {
                        "type": "string",
                        "description": "日期(YYYY-MM-DD)",
                        "name": "date",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/upload.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/upload.APIError"
                        }
                    }
                }
            },
            "delete": {
                "description": "通过相对路径删除图片，path 形如 2026-03-14/xxx.png",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "images"
                ],
                "summary": "删除图片",
                "parameters": [
                    {
                        "type": "string",
                        "description": "相对路径(YYYY-MM-DD/xxx.png)",
                        "name": "path",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/upload.APIResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/upload.APIError"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/upload.APIError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/upload.APIError"
                        }
                    }
                }
            }
        },
        "/info": {
            "get": {
                "description": "返回服务端存储目录与配置文件路径，供前端展示",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "info"
                ],
                "summary": "服务信息",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/upload.APIResponse"
                        }
                    }
                }
            }
        },
        "/upload": {
            "post": {
                "description": "上传一张图片并返回访问地址",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "images"
                ],
                "summary": "上传图片",
                "parameters": [
                    {
                        "type": "file",
                        "description": "图片文件",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "保存时的文件名（可选，上传前改名）",
                        "name": "filename",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/upload.APIResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/upload.APIError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/upload.APIError"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "upload.APIError": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 400
                },
                "data": {},
                "message": {
                    "type": "string",
                    "example": "missing path"
                }
            }
        },
        "upload.APIResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 200
                },
                "data": {},
                "message": {
                    "type": "string",
                    "example": "success"
                }
            }
        }
    }
}